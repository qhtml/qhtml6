        readonly: "readonly"
        style {
          min-height: 52vh;
          resize: vertical;
          font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
          white-space: pre;
        }
      }
    }
    footer {
      div.w3-right-align {
        button.w3-button.w3-small.w3-theme-l3.w3-round-large.w3-margin-right { type: "button" q-builder-action: "copy-source" onclick { this.closest("q-builder").copySource(); } text { Copy } }
        button.w3-button.w3-small.w3-theme-l3.w3-round-large.w3-margin-right { type: "button" q-builder-action: "download-source" onclick { this.closest("q-builder").downloadSource(); } text { Download } }
        button.w3-button.w3-small.w3-grey.w3-round-large { type: "button" q-builder-action: "close-source" onclick { this.component.hide(); this.closest("q-builder").markSourceModalClosed(); } q-builder-icon-close { } span.w3-margin-left { text { Close } } }
      }
    }
  }
}

