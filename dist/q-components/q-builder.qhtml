      var s = this.state();
      var nextStage = stage && typeof stage === "object" ? stage : null;
      s.stagedDrop = nextStage;
      s.slotChoices = nextStage && Array.isArray(nextStage.slotChoices) ? nextStage.slotChoices.slice() : [];
      var messageNode = this.querySelector("[q-builder-slot-picker-message='1']");
      if (messageNode) {
        var paletteLabel = nextStage && nextStage.paletteItem && nextStage.paletteItem.label
          ? String(nextStage.paletteItem.label || "").trim()
          : "";
        messageNode.textContent = nextStage
          ? "Choose a target slot for " + String(paletteLabel || nextStage.componentName || "component") + "."
          : "Choose a target slot for the dropped component.";
      }
      this.renderSlotPickerChoices(s.slotChoices);
      this.setSlotPickerOpen(true);
    } catch (error) {
      this.logIssue("openSlotPicker failed", error);
    }
  }

  function chooseSlot(slotName) {
    try {
      var s = this.state();
      var stage = s.stagedDrop && typeof s.stagedDrop === "object" ? s.stagedDrop : null;
      if (!stage || !stage.host || !stage.target) {
        this.setSlotPickerOpen(false);
