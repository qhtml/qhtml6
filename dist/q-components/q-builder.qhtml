      }, "slot picker content layout failed");
      this.applyStyles(body, { maxHeight: "48vh", overflow: "auto" }, "slot picker body layout failed");
    } catch (error) {
      this.logIssue("ensureSlotPickerLayout failed", error);
    }
  }

  function renderSlotPickerChoices(choices) {
    try {
      var listNode = this.querySelector("[q-builder-slot-picker-list='1']");
      var list = Array.isArray(choices) ? choices : [];
      var lines = ["div { q-builder-slot-picker-list: \"1\""];
      if (!list.length) {
        lines.push("  div.w3-small.w3-text-grey { text { No slots available. } }");
      } else {
        for (var i = 0; i < list.length; i += 1) {
          var choice = list[i] || {};
          var slotName = String(choice.slotName || "default").trim() || "default";
          var label = String(choice.label || slotName).trim() || slotName;
          lines.push("  button.w3-button.w3-block.w3-left-align.w3-theme-l3.w3-round.w3-margin-bottom { type: \"button\" q-builder-action: \"choose-slot\" q-builder-slot-choice: \"" + slotName + "\" onclick { this.closest(\"q-builder\").chooseSlot(\"" + slotName + "\"); } text { " + label + " } }");
        }
      }
      lines.push("}");
      var source = lines.join("\n");
      if (listNode && typeof listNode.qdom === "function" && listNode.qdom() && typeof listNode.qdom().replaceWithQHTML === "function") {
        listNode.qdom().replaceWithQHTML(source);
      } else if (listNode) {
        listNode.innerHTML = "";
      }
    } catch (error) {
      this.logIssue("renderSlotPickerChoices failed", error);
    }
  }

  function setSlotPickerOpen(openFlag) {
    try {
      var s = this.state();
