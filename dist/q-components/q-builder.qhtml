        return;
      }
      if (openFlag && typeof modal.show === "function") {
        modal.show();
        this.ensureSlotPickerLayout();
      } else if (!openFlag && typeof modal.hide === "function") {
        modal.hide();
        this.positionToolbar();
      } else {
        var root = modal.querySelector ? modal.querySelector("[q-modal-root='1'], .w3-modal") : null;
        this.applyStyles(root, { display: openFlag ? "block" : "none" }, "setSlotPickerOpen root fallback failed");
        if (openFlag) {
