      var applied = this.commitPaletteDropToSlot(stage.paletteItem || stage.componentName, stage.host, slotName, { target: stage.target });
      s.stagedDrop = null;
      s.slotChoices = [];
      this.setSlotPickerOpen(false);
      this.clearPaletteDropTarget();
      this.state().paletteDragName = "";
      return applied;
    } catch (error) {
      this.logIssue("chooseSlot failed", error);
      this.setSlotPickerOpen(false);
      return false;
    }
  }

  function setHoverElement(element) {
    var s = this.state();
    var next = element || null;
    if (s.hoverEl === next) { return; }
    s.hoverEl = next;
