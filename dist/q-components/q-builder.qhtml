      var naturalW = Math.ceil(content.scrollWidth || 0);
      var naturalH = Math.ceil(content.scrollHeight || 0);
      var nextW = Math.max(320, Math.min(maxW, naturalW || maxW));
      var nextH = Math.max(240, Math.min(maxH, naturalH || maxH));
