q-import { q-tabs.qhtml }

q-template q-builder-icon-edit { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; path { d: "M4 20h4l10-10-4-4L4 16z" } path { d: "M13 7l4 4" } } }
q-template q-builder-icon-save { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; path { d: "M5 3h12l2 2v16H5z" } path { d: "M9 3v6h6V3" } } }
q-template q-builder-icon-close { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; path { d: "M6 6l12 12" } path { d: "M18 6L6 18" } } }
q-template q-builder-icon-colors { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; stroke-width: "2"; stroke-linecap: "round"; stroke-linejoin: "round"; path { d: "M12 3a9 9 0 1 0 0 18h1.1a2.6 2.6 0 0 0 0-5.2h-.8a2.1 2.1 0 0 1 0-4.2h2.2A3.5 3.5 0 0 0 18.2 8 5.2 5.2 0 0 0 13 3z" } circle { cx: "7.4"; cy: "9"; r: "1.2"; fill: "currentColor"; stroke: "none" } circle { cx: "10.4"; cy: "6.8"; r: "1.2"; fill: "currentColor"; stroke: "none" } circle { cx: "14.3"; cy: "7.4"; r: "1.2"; fill: "currentColor"; stroke: "none" } circle { cx: "16.1"; cy: "11"; r: "1.2"; fill: "currentColor"; stroke: "none" } } }
q-template q-builder-icon-parent { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; stroke-width: "2"; stroke-linecap: "round"; stroke-linejoin: "round"; path { d: "M9 8l-4 4 4 4" } path { d: "M5 12h9a5 5 0 0 1 5 5" } } }
q-template q-builder-icon-duplicate { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; stroke-width: "2"; stroke-linecap: "round"; stroke-linejoin: "round"; rect { x: "9"; y: "9"; width: "10"; height: "10"; rx: "2" } path { d: "M15 9V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" } } }
q-template q-builder-icon-delete { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; stroke-width: "2"; stroke-linecap: "round"; stroke-linejoin: "round"; path { d: "M4 7h16" } path { d: "M10 11v6" } path { d: "M14 11v6" } path { d: "M6 7l1 12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-12" } path { d: "M9 7V4h6v3" } } }
q-template q-builder-icon-source { svg { viewBox: "0 0 24 24"; width: "16"; height: "16"; fill: "none"; stroke: "currentColor"; stroke-width: "2"; stroke-linecap: "round"; stroke-linejoin: "round"; path { d: "M8 8L4 12l4 4" } path { d: "M16 8l4 4-4 4" } } }

q-component q-builder-toolbar {
  div.w3-bar.w3-theme-l2.w3-round-large.w3-padding-small { q-builder-toolbar: "1"
    style {
      position: fixed;
      left: 0;
      top: 0;
      display: none;
      z-index: 1001;
      transform: translate(-50%, -100%);
      margin-top: -8px;
      align-items: center;
      gap: 0.35rem;
      flex-wrap: wrap;
      max-width: min(92vw, 56rem);
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.18);
    }
    button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "open" onclick { this.closest("q-builder").showSelectedEditor(); } q-builder-icon-edit { } span.w3-margin-left { text { Edit } } }
    button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "open-colors" onclick { this.closest("q-builder").showColorsEditor(); } q-builder-icon-colors { } span.w3-margin-left { text { Colors } } }
    button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "select-parent" onclick { this.closest("q-builder").selectParentElement(); } q-builder-icon-parent { } span.w3-margin-left { text { Parent } } }
    button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "duplicate-selected" onclick { this.closest("q-builder").duplicateSelected(); } q-builder-icon-duplicate { } span.w3-margin-left { text { Duplicate } } }
    button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "open-source-selected" onclick { this.closest("q-builder").showSourceDialogForSelected(); } q-builder-icon-source { } span.w3-margin-left { text { Source } } }
    button.w3-button.w3-small.w3-red.w3-round-large { type: "button" q-builder-action: "remove-selected" onclick { this.closest("q-builder").removeSelected(); } q-builder-icon-delete { } span.w3-margin-left { text { Delete } } }
  }
}

q-component q-builder-palette {
  q-property mode: "floating"
  q-property catalogMode: "auto"

  function excludedPaletteNames() {
    return {
      "q-builder": true,
      "q-builder-palette": true,
      "q-builder-toolbar": true,
      "q-builder-shell": true,
      "q-builder-modal-shell": true,
      "q-builder-colors-modal-shell": true,
      "q-builder-source-modal-shell": true,
      "q-builder-slot-picker-modal-shell": true
    };
  }

  function isExcludedPaletteName(name) {
    var value = String(name || "").trim().toLowerCase();
    return !!this.excludedPaletteNames()[value];
  }

  function getGlobalRef() {
    return typeof globalThis !== "undefined" ? globalThis : Function("return this")();
  }

  function logIssue(label, error) {
    try {
      var root = this.getGlobalRef();
      var logger = root && root.console ? root.console : console;
      if (logger && typeof logger.log === "function") {
        logger.log("[q-builder-palette] " + String(label || "error"), error);
      }
    } catch (ignored) { }
  }

  function state() {
    if (!this.__qBuilderPaletteState || typeof this.__qBuilderPaletteState !== "object") {
      this.__qBuilderPaletteState = {
        activeName: "",
        activeCell: null,
        drag: { active: false, startX: 0, startY: 0, left: 0, top: 0 },
        itemDrag: { active: false, moved: false, name: "", ghost: null },
        host: null,
        names: [],
        refreshTimer: null,
        scanRequestId: 0,
        scanWorker: null,
        scanWorkerUrl: ""
      };
    }
    return this.__qBuilderPaletteState;
  }

  function panel() {
    return this.querySelector("[q-builder-palette='1']");
  }

  function grid() {
    return this.querySelector("[q-builder-palette-grid='1']");
  }

  function currentMode() {
    var raw = null;
    if (this.getAttribute) {
      raw = this.getAttribute("mode");
    }
    if (raw == null || raw === "") {
      raw = this.mode;
    }
    raw = String(raw || "floating").trim().toLowerCase();
    if (raw === "embedded" || raw === "hidden") { return raw; }
    return "floating";
  }

  function currentCatalogMode() {
    var raw = null;
    if (this.getAttribute) {
      raw = this.getAttribute("catalogMode");
    }
    if (raw == null || raw === "") {
      raw = this.catalogMode;
    }
    raw = String(raw || "auto").trim().toLowerCase();
    if (raw === "catalog" || raw === "mixed") { return raw; }
    return "auto";
  }

  function isEmbeddedMode() {
    return this.currentMode() === "embedded";
  }

  function isHiddenMode() {
    return this.currentMode() === "hidden";
  }

  function applyLayoutMode() {
    try {
      var panel = this.panel();
      var handle = this.querySelector("[q-builder-palette-handle='1']");
      if (!panel || !panel.style) { return; }
      var mode = this.currentMode();
      if (mode === "hidden") {
        panel.style.display = "none";
        return;
      }
      panel.style.display = "flex";
      if (mode === "embedded") {
        panel.style.position = "relative";
        panel.style.left = "0";
        panel.style.top = "0";
        panel.style.right = "auto";
        panel.style.width = "100%";
        panel.style.height = "100%";
        panel.style.minWidth = "0";
        panel.style.minHeight = "0";
        panel.style.maxWidth = "none";
        panel.style.maxHeight = "none";
        panel.style.resize = "none";
        panel.style.zIndex = "1";
        panel.style.boxShadow = "none";
        panel.style.borderRadius = "0";
      } else {
        panel.style.position = "fixed";
        panel.style.left = "auto";
        panel.style.top = "8vh";
        panel.style.right = "1vw";
        panel.style.width = "42vw";
        panel.style.height = "42vh";
        panel.style.minWidth = "22rem";
        panel.style.minHeight = "16rem";
        panel.style.maxWidth = "90vw";
        panel.style.maxHeight = "90vh";
        panel.style.resize = "both";
        panel.style.zIndex = "1200";
        panel.style.boxShadow = "0 12px 30px rgba(0, 0, 0, 0.35)";
        panel.style.borderRadius = "";
      }
      if (handle && handle.style) {
        handle.style.cursor = mode === "floating" ? "move" : "default";
      }
    } catch (error) {
      this.logIssue("applyLayoutMode failed", error);
    }
  }

  function sanitizeName(name) {
    var value = String(name || "").trim().toLowerCase();
    if (!value || value.indexOf("q-") !== 0) { return ""; }
    if (value === "q-html" || value === "q-script" || value === "slot") { return ""; }
    if (this.isExcludedPaletteName(value)) { return ""; }
    return value;
  }

  function normalizeCatalogEntry(entry) {
    try {
      var raw = entry && typeof entry === "object" ? entry : null;
      if (!raw) { return null; }
      var componentName = this.sanitizeName(raw.componentName || raw.name || raw.component || "");
      var insertQhtml = raw.insertQhtml != null ? String(raw.insertQhtml || "").trim() : "";
      if (!componentName && !insertQhtml) { return null; }
      var label = String(raw.label || componentName || raw.id || "widget").trim() || "widget";
      var key = String(raw.id || componentName || label || "").trim().toLowerCase();
      key = key.replace(/[^a-z0-9_-]+/g, "-").replace(/^-+|-+$/g, "");
      if (!key) { key = componentName || "widget"; }
      return {
        id: key,
        label: label,
        componentName: componentName,
        insertQhtml: insertQhtml,
        previewHtml: String(raw.previewHtml || "").trim(),
        description: String(raw.description || "").trim()
      };
    } catch (error) {
      this.logIssue("normalizeCatalogEntry failed", error);
      return null;
    }
  }

  function currentCatalog() {
    return Array.isArray(this.__qBuilderPaletteCatalog) ? this.__qBuilderPaletteCatalog.slice() : [];
  }

  function setCatalog(entries) {
    try {
      var list = Array.isArray(entries) ? entries : [];
      var out = [];
      var seen = {};
      for (var i = 0; i < list.length; i += 1) {
        var normalized = this.normalizeCatalogEntry(list[i]);
        if (!normalized) { continue; }
        var key = String(normalized.id || "").trim().toLowerCase();
        if (!key || seen[key]) { continue; }
        seen[key] = true;
        out.push(normalized);
      }
      this.__qBuilderPaletteCatalog = out;
      return this.refresh(this.findHost());
    } catch (error) {
      this.logIssue("setCatalog failed", error);
      return Promise.resolve([]);
    }
  }

  function buildScanWorkerScript() {
    return [
      "const EXCLUDED = new Set(['q-builder','q-builder-palette','q-builder-toolbar','q-builder-shell','q-builder-modal-shell','q-builder-colors-modal-shell','q-builder-source-modal-shell','q-builder-slot-picker-modal-shell']);",
      "function sanitizeName(name) {",
      "  var value = String(name || '').trim().toLowerCase();",
      "  if (!value || value.indexOf('q-') !== 0) { return ''; }",
      "  if (value === 'q-html' || value === 'q-script' || value === 'slot') { return ''; }",
      "  if (EXCLUDED.has(value)) { return ''; }",
      "  return value;",
      "}",
      "",
      "function collectNames(payload) {",
      "  var html = String(payload && payload.html ? payload.html : '');",
      "  var out = Object.create(null);",
      "  var match = null;",
      "  var tagRegex = /<\\s*([A-Za-z][\\w:-]*)\\b/g;",
      "  while ((match = tagRegex.exec(html))) {",
      "    var name = sanitizeName(match[1]);",
      "    if (name) { out[name] = 1; }",
      "  }",
      "  return Object.keys(out).sort();",
      "}",
      "",
      "self.onmessage = function(event) {",
      "  var data = event && event.data ? event.data : {};",
      "  if (String(data.type || '') !== 'scan') { return; }",
      "  var names = collectNames(data);",
      "  self.postMessage({ type: 'scanResult', requestId: Number(data.requestId || 0), names: names });",
      "};"
    ].join("\n");
  }

  function ensureScanWorker() {
    try {
      var s = this.state();
      if (s.scanWorker && typeof s.scanWorker.postMessage === "function") { return s.scanWorker; }
      var root = this.getGlobalRef();
      if (!root || typeof root.Worker !== "function" || typeof root.Blob !== "function") { return null; }
      if (!root.URL || typeof root.URL.createObjectURL !== "function") { return null; }
      var script = this.buildScanWorkerScript();
      var blob = new root.Blob([script], { type: "application/javascript" });
      var workerUrl = root.URL.createObjectURL(blob);
      var worker = new root.Worker(workerUrl);
      s.scanWorker = worker;
      s.scanWorkerUrl = workerUrl;
      return worker;
    } catch (error) {
      this.logIssue("ensureScanWorker failed", error);
      return null;
    }
  }

  function collectComponentNamesWithWorker(host, requestId) {
    var self = this;
    return new Promise(function(resolve) {
      try {
        var worker = self.ensureScanWorker();
        if (!worker) {
          resolve(null);
          return;
        }
        var resolved = false;
        var timeoutId = null;
        var done = function(result) {
          if (resolved) { return; }
          resolved = true;
          if (timeoutId) { clearTimeout(timeoutId); }
          try { worker.removeEventListener("message", handleMessage); } catch (ignoredMessage) { }
          try { worker.removeEventListener("error", handleError); } catch (ignoredError) { }
          resolve(result);
        };
        var handleMessage = function(event) {
          try {
            var data = event && event.data ? event.data : {};
            if (String(data.type || "") !== "scanResult") { return; }
            if (Number(data.requestId || 0) !== Number(requestId || 0)) { return; }
            var rawNames = Array.isArray(data.names) ? data.names : [];
            var dedupe = {};
            var list = [];
            for (var i = 0; i < rawNames.length; i += 1) {
              var name = self.sanitizeName(rawNames[i]);
              if (!name || dedupe[name]) { continue; }
              dedupe[name] = true;
              list.push(name);
            }
            list.sort();
            done(list);
          } catch (error) {
            self.logIssue("collectComponentNamesWithWorker message failed", error);
            done(null);
          }
        };
        var handleError = function(error) {
          self.logIssue("collectComponentNamesWithWorker worker error", error);
          done(null);
        };
        worker.addEventListener("message", handleMessage);
        worker.addEventListener("error", handleError);
        timeoutId = setTimeout(function() { done(null); }, 10000);
        worker.postMessage({
          type: "scan",
          requestId: Number(requestId || 0),
          html: host && typeof host.innerHTML === "string" ? host.innerHTML : ""
        });
      } catch (error) {
        self.logIssue("collectComponentNamesWithWorker failed", error);
        resolve(null);
      }
    });
  }

  function collectComponentNamesAsync(host, requestId) {
    try {
      var targetHost = host && host.nodeType === 1 ? host : this.findHost();
      var self = this;
      return this.collectComponentNamesWithWorker(targetHost, requestId).then(function(workerNames) {
        if (Array.isArray(workerNames)) { return workerNames; }
        return self.collectComponentNames();
      });
    } catch (error) {
      this.logIssue("collectComponentNamesAsync failed", error);
      return Promise.resolve([]);
    }
  }

  function collectComponentsFromDoc(documentNode, outputSet) {
    try {
      var self = this;
      var root = this.getGlobalRef();
      var modules = root && root.QHtmlModules ? root.QHtmlModules : null;
      var core = modules && modules.qdomCore ? modules.qdomCore : null;
      if (!documentNode || typeof documentNode !== "object") { return; }
      function pushName(value) {
        var name = self.sanitizeName(value);
        if (name) { outputSet.add(name); }
      }
      function readNode(node) {
        var kind = String(node && node.kind ? node.kind : "").toLowerCase();
        if (kind === "component") {
          if (String(node.definitionType || "component").toLowerCase() === "component") {
            pushName(node.componentId);
          }
          return;
        }
        if (kind === "component-instance" || kind === "template-instance") {
          pushName(node.componentId || node.tagName);
          return;
        }
        if (kind === "element") {
          pushName(node.tagName);
        }
      }
      if (core && typeof core.walkQDom === "function") {
        core.walkQDom(documentNode, readNode);
        return;
      }
      var stack = [documentNode];
      while (stack.length > 0) {
        var node = stack.pop();
        readNode(node);
        if (!node || typeof node !== "object") { continue; }
        if (Array.isArray(node.nodes)) {
          for (var ni = 0; ni < node.nodes.length; ni += 1) { stack.push(node.nodes[ni]); }
        }
        if (Array.isArray(node.children)) {
          for (var ci = 0; ci < node.children.length; ci += 1) { stack.push(node.children[ci]); }
        }
        if (Array.isArray(node.templateNodes)) {
          for (var ti = 0; ti < node.templateNodes.length; ti += 1) { stack.push(node.templateNodes[ti]); }
        }
        if (Array.isArray(node.slots)) {
          for (var si = 0; si < node.slots.length; si += 1) { stack.push(node.slots[si]); }
        }
      }
    } catch (error) {
      this.logIssue("collectComponentsFromDoc failed", error);
    }
  }

  function findHost() {
    var s = this.state();
    if (s.host && s.host.nodeType === 1) { return s.host; }
    return this.closest ? this.closest("q-html") : null;
  }

  function collectComponentNames() {
    var names = new Set();
    try {
      var root = this.getGlobalRef();
      var runtime = root && root.QHtml ? root.QHtml : (root && root.QHtmlModules ? root.QHtmlModules.qhtmlRuntime : null);
      if (runtime && typeof runtime.listRegisteredComponentIds === "function") {
        var registered = runtime.listRegisteredComponentIds();
        for (var ri = 0; ri < registered.length; ri += 1) {
          var registeredName = this.sanitizeName(registered[ri]);
          if (registeredName) { names.add(registeredName); }
        }
      }
      var doc = this.ownerDocument || (typeof document !== "undefined" ? document : null);
      var hosts = [];
      var preferredHost = this.findHost();
      if (preferredHost && preferredHost.nodeType === 1) {
        hosts.push(preferredHost);
      } else if (doc && typeof doc.querySelectorAll === "function") {
        var allHosts = doc.querySelectorAll("q-html");
        for (var i = 0; i < allHosts.length; i += 1) { hosts.push(allHosts[i]); }
      }
      for (var h = 0; h < hosts.length; h += 1) {
        var host = hosts[h];
        if (!host || typeof host.qdom !== "function") { continue; }
        var qdomNode = host.qdom();
        var docNode = qdomNode;
        if (docNode && String(docNode.kind || "").toLowerCase() !== "document" && typeof docNode.root === "function") {
          docNode = docNode.root();
        }
        if (docNode && String(docNode.kind || "").toLowerCase() === "document") {
          this.collectComponentsFromDoc(docNode, names);
        }
      }
    } catch (error) {
      this.logIssue("collectComponentNames failed", error);
    }
    var list = Array.from(names);
    list.sort();
    return list;
  }

  function setActiveCell(cell, name) {
    try {
      var s = this.state();
      if (s.activeCell && s.activeCell.style) {
        s.activeCell.style.borderColor = "#5f7088";
      }
      s.activeCell = cell || null;
      s.activeName = String(name || "").toLowerCase();
      if (s.activeCell && s.activeCell.style) {
        s.activeCell.style.borderColor = "#ffe500";
      }
      this.setAttribute("q-builder-palette-active", s.activeName);
      if (typeof CustomEvent === "function") {
        this.dispatchEvent(new CustomEvent("q-builder-palette:select", {
          bubbles: true,
          detail: { name: s.activeName }
        }));
      }
    } catch (error) {
      this.logIssue("setActiveCell failed", error);
    }
  }

  function emitItemDragEvent(eventName, item, event) {
    try {
      var normalized = this.normalizeCatalogEntry(item);
      if (!normalized) {
        var componentName = this.sanitizeName(item);
        normalized = componentName ? {
          id: componentName,
          label: componentName,
          componentName: componentName,
          insertQhtml: "",
          previewHtml: "",
          description: ""
        } : null;
      }
      if (!normalized) { return; }
      var payload = {
        name: String(normalized.componentName || normalized.id || "").trim().toLowerCase(),
        item: normalized,
        clientX: event && typeof event.clientX === "number" ? Number(event.clientX) : 0,
        clientY: event && typeof event.clientY === "number" ? Number(event.clientY) : 0
      };
      if (typeof CustomEvent === "function") {
        this.dispatchEvent(new CustomEvent(eventName, {
          bubbles: true,
          composed: true,
          detail: payload
        }));
      }
    } catch (error) {
      this.logIssue("emitItemDragEvent failed", error);
    }
  }

  function createItemDragGhost(item) {
    try {
      var doc = this.ownerDocument || document;
      var ghost = doc.createElement("div");
      var normalized = this.normalizeCatalogEntry(item);
      if (!normalized) {
        var componentName = this.sanitizeName(item);
        normalized = componentName ? { label: componentName, componentName: componentName } : null;
      }
      ghost.textContent = String(normalized && (normalized.label || normalized.componentName) || "").trim() || "widget";
      ghost.style.position = "fixed";
      ghost.style.left = "0";
      ghost.style.top = "0";
      ghost.style.pointerEvents = "none";
      ghost.style.zIndex = "1600";
      ghost.style.padding = "0.22rem 0.45rem";
      ghost.style.borderRadius = "0.32rem";
      ghost.style.border = "1px solid #f59e0b";
      ghost.style.background = "rgba(15, 23, 42, 0.92)";
      ghost.style.color = "#fde68a";
      ghost.style.fontSize = "0.68rem";
      ghost.style.fontWeight = "700";
      ghost.style.letterSpacing = "0.02em";
      return ghost;
    } catch (error) {
      this.logIssue("createItemDragGhost failed", error);
      return null;
    }
  }

  function positionItemDragGhost(event) {
    try {
      var s = this.state();
      var ghost = s.itemDrag && s.itemDrag.ghost ? s.itemDrag.ghost : null;
      if (!ghost || !ghost.style || !event) { return; }
      var x = typeof event.clientX === "number" ? Number(event.clientX) : 0;
      var y = typeof event.clientY === "number" ? Number(event.clientY) : 0;
      ghost.style.transform = "translate(" + Math.round(x + 14) + "px, " + Math.round(y + 14) + "px)";
    } catch (error) {
      this.logIssue("positionItemDragGhost failed", error);
    }
  }

  function startItemDrag(item, cell, event) {
    try {
      var normalized = this.normalizeCatalogEntry(item);
      if (!normalized) {
        var componentName = this.sanitizeName(item);
        normalized = componentName ? {
          id: componentName,
          label: componentName,
          componentName: componentName,
          insertQhtml: "",
          previewHtml: "",
          description: ""
        } : null;
      }
      if (!normalized || !event || Number(event.button) !== 0) { return; }
      var s = this.state();
      this.setActiveCell(cell || null, normalized.id || normalized.componentName || normalized.label);
      s.itemDrag.active = true;
      s.itemDrag.moved = false;
      s.itemDrag.name = String(normalized.id || normalized.componentName || "").trim().toLowerCase();
      s.itemDrag.item = normalized;
      var ghost = this.createItemDragGhost(normalized);
      s.itemDrag.ghost = ghost;
      if (ghost && ghost.ownerDocument && ghost.ownerDocument.body) {
        ghost.ownerDocument.body.appendChild(ghost);
      }
      this.positionItemDragGhost(event);
      this.emitItemDragEvent("q-builder-palette:itemdragstart", normalized, event);
      event.preventDefault();
      event.stopPropagation();
    } catch (error) {
      this.logIssue("startItemDrag failed", error);
    }
  }

  function moveItemDrag(event) {
    try {
      var s = this.state();
      if (!s.itemDrag.active) { return; }
      s.itemDrag.moved = true;
      this.positionItemDragGhost(event);
      this.emitItemDragEvent("q-builder-palette:itemdragmove", s.itemDrag.item || s.itemDrag.name, event);
    } catch (error) {
      this.logIssue("moveItemDrag failed", error);
    }
  }

  function endItemDrag(event) {
    try {
      var s = this.state();
      if (!s.itemDrag.active) { return; }
      this.emitItemDragEvent("q-builder-palette:itemdragend", s.itemDrag.item || s.itemDrag.name, event || {});
      var ghost = s.itemDrag.ghost;
      if (ghost && ghost.parentNode && typeof ghost.parentNode.removeChild === "function") {
        ghost.parentNode.removeChild(ghost);
      }
      s.itemDrag.active = false;
      s.itemDrag.moved = false;
      s.itemDrag.name = "";
      s.itemDrag.item = null;
      s.itemDrag.ghost = null;
    } catch (error) {
      this.logIssue("endItemDrag failed", error);
    }
  }

  function resolvePreviewSource(componentName, host) {
    try {
      var scope = host && host.querySelectorAll ? host : (this.ownerDocument || document);
      var matches = scope.querySelectorAll(componentName);
      for (var i = 0; i < matches.length; i += 1) {
        var candidate = matches[i];
        if (!candidate || candidate === this || (candidate.closest && candidate.closest("q-builder-palette"))) { continue; }
        return candidate;
      }
    } catch (error) {
      this.logIssue("resolvePreviewSource failed", error);
    }
    return null;
  }

  function isCustomTagName(tagName) {
    var name = String(tagName || "").trim().toLowerCase();
    return !!name && name.indexOf("q-") === 0;
  }

  function createPreviewPlaceholder(name, doc, kind) {
    var node = (doc || document).createElement("div");
    node.textContent = String(name || kind || "preview");
    node.style.display = "flex";
    node.style.alignItems = "center";
    node.style.justifyContent = "center";
    node.style.width = "100%";
    node.style.height = "100%";
    node.style.minHeight = "2rem";
    node.style.fontSize = "0.62rem";
    node.style.fontWeight = "700";
    node.style.letterSpacing = "0.02em";
    node.style.textTransform = "lowercase";
    node.style.color = "#93c5fd";
    node.style.background = "linear-gradient(135deg, #0f172a 0%, #1e293b 100%)";
    node.style.border = "1px dashed rgba(148, 163, 184, 0.55)";
    node.style.borderRadius = "0.25rem";
    node.setAttribute("q-builder-preview-placeholder", String(kind || "node"));
    return node;
  }

  function makePreviewCloneInert(node, componentName) {
    try {
      var doc = this.ownerDocument || document;
      var fallbackName = String(componentName || "q-component").trim().toLowerCase() || "q-component";
      var root = node;
      if (!root || root.nodeType !== 1) {
        return this.createPreviewPlaceholder(fallbackName, doc, "empty");
      }
      if (this.isCustomTagName(root.tagName) || String(root.tagName || "").toLowerCase() === "form") {
        root = this.createPreviewPlaceholder(fallbackName, doc, String(root.tagName || "custom").toLowerCase());
      }
      var customNodes = root.querySelectorAll ? root.querySelectorAll("*") : [];
      for (var i = customNodes.length - 1; i >= 0; i -= 1) {
        var candidate = customNodes[i];
        if (!candidate || candidate.nodeType !== 1 || !candidate.parentNode) { continue; }
        var tag = String(candidate.tagName || "").toLowerCase();
        if (this.isCustomTagName(tag) || tag === "form") {
          candidate.parentNode.replaceChild(this.createPreviewPlaceholder(tag, doc, tag), candidate);
        }
      }
      var controls = root.querySelectorAll ? root.querySelectorAll("input,textarea,select,button") : [];
      for (var ci = 0; ci < controls.length; ci += 1) {
        var control = controls[ci];
        if (!control || control.nodeType !== 1) { continue; }
        var controlTag = String(control.tagName || "").toLowerCase();
        if (!control.getAttribute("name")) {
          control.setAttribute("name", "preview-" + fallbackName + "-" + controlTag + "-" + String(ci));
        }
        if (!control.getAttribute("id")) {
          control.setAttribute("id", "preview-" + fallbackName + "-" + controlTag + "-" + String(ci));
        }
        control.setAttribute("autocomplete", "off");
        control.setAttribute("aria-hidden", "true");
        control.setAttribute("tabindex", "-1");
        control.disabled = true;
      }
      return root;
    } catch (error) {
      this.logIssue("makePreviewCloneInert failed", error);
      return this.createPreviewPlaceholder(componentName, this.ownerDocument || document, "error");
    }
  }

  function buildPreviewNode(componentName, host) {
    var doc = this.ownerDocument || document;
    var previewLayer = doc.createElement("div");
    previewLayer.setAttribute("q-builder-palette-preview-layer", "1");
    previewLayer.style.position = "absolute";
    previewLayer.style.left = "0";
    previewLayer.style.top = "0";
    previewLayer.style.right = "0";
    previewLayer.style.bottom = "0";
    previewLayer.style.overflow = "hidden";
    previewLayer.style.background = "#111827";
    var scale = doc.createElement("div");
    scale.style.position = "absolute";
    scale.style.left = "0";
    scale.style.top = "0";
    scale.style.width = "400%";
    scale.style.height = "400%";
    scale.style.transform = "scale(0.25)";
    scale.style.transformOrigin = "0 0";
    scale.style.pointerEvents = "none";
    var source = this.resolvePreviewSource(componentName, host);
    var normalizedName = String(componentName || "").trim().toLowerCase();
    var node = null;
    var skipClone = normalizedName === "q-builder" || normalizedName === "q-builder-palette";
    if (!skipClone && source && typeof source.cloneNode === "function") {
      try {
        node = source.cloneNode(true);
        node = this.makePreviewCloneInert(node, componentName);
      } catch (error) {
        node = null;
        this.logIssue("clone preview failed", error);
      }
    }
    if (!node) {
      node = doc.createElement("div");
      node.textContent = componentName;
      node.style.display = "flex";
      node.style.alignItems = "center";
      node.style.justifyContent = "center";
      node.style.width = "100%";
      node.style.height = "100%";
      node.style.fontSize = "2rem";
      node.style.fontWeight = "bold";
      node.style.color = "#38bdf8";
      node.style.background = "linear-gradient(135deg, #0f172a 0%, #1e293b 100%)";
    }
    node.setAttribute("q-builder-palette-preview-node", "1");
    node.style.pointerEvents = "none";
    scale.appendChild(node);
    previewLayer.appendChild(scale);
    return previewLayer;
  }

  function buildCatalogPreviewNode(entry, host) {
    try {
      var normalized = this.normalizeCatalogEntry(entry);
      if (!normalized) { return this.buildPreviewNode("", host); }
      if (!normalized.previewHtml) {
        return this.buildPreviewNode(normalized.componentName || normalized.label, host);
      }
      var doc = this.ownerDocument || document;
      var previewLayer = doc.createElement("div");
      previewLayer.setAttribute("q-builder-palette-preview-layer", "1");
      previewLayer.style.position = "absolute";
      previewLayer.style.left = "0";
      previewLayer.style.top = "0";
      previewLayer.style.right = "0";
      previewLayer.style.bottom = "0";
      previewLayer.style.overflow = "hidden";
      previewLayer.style.background = "#111827";
      var scale = doc.createElement("div");
      scale.style.position = "absolute";
      scale.style.left = "0";
      scale.style.top = "0";
      scale.style.width = "400%";
      scale.style.height = "400%";
      scale.style.transform = "scale(0.25)";
      scale.style.transformOrigin = "0 0";
      scale.style.pointerEvents = "none";
      var wrapper = doc.createElement("div");
      wrapper.style.width = "100%";
      wrapper.style.height = "100%";
      wrapper.innerHTML = normalized.previewHtml;
      var controls = wrapper.querySelectorAll ? wrapper.querySelectorAll("input,textarea,select,button") : [];
      for (var i = 0; i < controls.length; i += 1) {
        controls[i].disabled = true;
        controls[i].setAttribute("tabindex", "-1");
        controls[i].setAttribute("aria-hidden", "true");
      }
      var previewNode = wrapper;
      previewNode.setAttribute("q-builder-palette-preview-node", "1");
      previewNode.style.pointerEvents = "none";
      scale.appendChild(previewNode);
      previewLayer.appendChild(scale);
      return previewLayer;
    } catch (error) {
      this.logIssue("buildCatalogPreviewNode failed", error);
      return this.buildPreviewNode("", host);
    }
  }

  function clearGrid() {
    try {
      var grid = this.grid();
      if (!grid) { return; }
      while (grid.firstChild) { grid.removeChild(grid.firstChild); }
    } catch (error) {
      this.logIssue("clearGrid failed", error);
    }
  }

  function renderPaletteEntries(entries, host) {
    try {
      var s = this.state();
      var grid = this.grid();
      if (!grid) { return []; }
      s.names = entries.slice();
      this.clearGrid();
      for (var i = 0; i < entries.length; i += 1) {
        var entry = this.normalizeCatalogEntry(entries[i]);
        if (!entry) { continue; }
        var cell = (this.ownerDocument || document).createElement("button");
        cell.type = "button";
        cell.setAttribute("q-builder-palette-cell", "1");
        cell.setAttribute("q-builder-palette-component", entry.id);
        cell.style.position = "relative";
        cell.style.display = "block";
        cell.style.width = "100%";
        cell.style.height = "100%";
        cell.style.padding = "0";
        cell.style.margin = "0";
        cell.style.border = "2px solid #5f7088";
        cell.style.borderRadius = "0.35rem";
        cell.style.background = "#0f172a";
        cell.style.overflow = "hidden";
        cell.style.cursor = "pointer";
        var previewNode = this.buildCatalogPreviewNode(entry, host);
        var label = (this.ownerDocument || document).createElement("div");
        label.setAttribute("q-builder-palette-label", "1");
        label.textContent = entry.label;
        label.style.position = "absolute";
        label.style.left = "0";
        label.style.right = "0";
        label.style.bottom = "0";
        label.style.padding = "0.18rem 0.25rem";
        label.style.background = "rgba(0, 0, 0, 0.55)";
        label.style.color = "#f8fafc";
        label.style.fontSize = "0.58rem";
        label.style.lineHeight = "1.1";
        label.style.fontWeight = "600";
        label.style.textAlign = "left";
        cell.appendChild(previewNode);
        cell.appendChild(label);
        var self = this;
        (function attachSelect(targetCell, targetEntry) {
          targetCell.addEventListener("click", function(event) {
            try {
              event.preventDefault();
              event.stopPropagation();
              self.setActiveCell(targetCell, targetEntry.id || targetEntry.componentName || targetEntry.label);
            } catch (error) {
              self.logIssue("palette cell click failed", error);
            }
          });
          targetCell.addEventListener("mousedown", function(event) {
            try {
              self.startItemDrag(targetEntry, targetCell, event);
            } catch (error) {
              self.logIssue("palette cell mousedown failed", error);
            }
          });
        })(cell, entry);
        grid.appendChild(cell);
      }
      if (s.activeName) {
        var activeCell = grid.querySelector("[q-builder-palette-component='" + s.activeName + "']");
        if (activeCell) { this.setActiveCell(activeCell, s.activeName); }
      }
      return entries;
    } catch (error) {
      this.logIssue("renderPaletteEntries failed", error);
      return [];
    }
  }

  function rebuildPalette() {
    try {
      var s = this.state();
      var grid = this.grid();
      var host = this.findHost();
      if (!grid) { return Promise.resolve([]); }
      s.scanRequestId = Number(s.scanRequestId || 0) + 1;
      var requestId = s.scanRequestId;
      this.clearGrid();
      var loading = (this.ownerDocument || document).createElement("div");
      loading.textContent = this.isHiddenMode() ? "" : "Scanning components...";
      loading.style.color = "#cbd5e1";
      loading.style.fontSize = "0.8rem";
      loading.style.padding = "0.35rem 0.5rem";
      grid.appendChild(loading);
      var self = this;
      var catalogMode = this.currentCatalogMode();
      var explicitCatalog = this.currentCatalog();
      if (catalogMode === "catalog") {
        return Promise.resolve(this.renderPaletteEntries(explicitCatalog, host));
      }
      return this.collectComponentNamesAsync(host, requestId).then(function(names) {
        var latestState = self.state();
        if (Number(latestState.scanRequestId || 0) !== Number(requestId || 0)) { return []; }
        var list = [];
        var seen = {};
        if (catalogMode === "mixed") {
          for (var ci = 0; ci < explicitCatalog.length; ci += 1) {
            var catalogEntry = self.normalizeCatalogEntry(explicitCatalog[ci]);
            var catalogKey = catalogEntry ? String(catalogEntry.id || "").trim().toLowerCase() : "";
            if (!catalogEntry || !catalogKey || seen[catalogKey]) { continue; }
            seen[catalogKey] = true;
            list.push(catalogEntry);
          }
        }
        var rawNames = Array.isArray(names) ? names : [];
        for (var ni = 0; ni < rawNames.length; ni += 1) {
          var componentName = self.sanitizeName(rawNames[ni]);
          if (!componentName || seen[componentName]) { continue; }
          seen[componentName] = true;
          list.push({
            id: componentName,
            label: componentName,
            componentName: componentName,
            insertQhtml: "",
            previewHtml: "",
            description: ""
          });
        }
        return self.renderPaletteEntries(list, host);
      }).catch(function(error) {
        self.logIssue("rebuildPalette failed", error);
        return [];
      });
    } catch (error) {
      this.logIssue("rebuildPalette failed", error);
      return Promise.resolve([]);
    }
  }

  function setHost(host) {
    var s = this.state();
    s.host = host && host.nodeType === 1 ? host : null;
    return this.refresh(s.host);
  }

  function refresh(host) {
    var s = this.state();
    if (host && host.nodeType === 1) { s.host = host; }
    if (s.refreshTimer) {
      clearTimeout(s.refreshTimer);
      s.refreshTimer = null;
    }
    var self = this;
    return new Promise(function(resolve) {
      s.refreshTimer = setTimeout(function() {
        s.refreshTimer = null;
        Promise.resolve(self.rebuildPalette()).then(resolve)["catch"](function() { resolve([]); });
      }, 120);
    });
  }

  function bindDrag() {
    try {
      if (this.__qBuilderPaletteDragBound) { return; }
      this.__qBuilderPaletteDragBound = true;
      var self = this;
      var handle = this.querySelector("[q-builder-palette-handle='1']");
      var panel = this.panel();
      var doc = this.ownerDocument || document;
      if (!handle || !panel || !doc) { return; }
      handle.addEventListener("mousedown", function(event) {
        try {
          if (!self || typeof self.currentMode !== "function" || self.currentMode() !== "floating") { return; }
          if (event.button !== 0) { return; }
          if (event.target && event.target.closest && event.target.closest("[q-builder-palette-action]")) { return; }
          var rect = panel.getBoundingClientRect();
          var s = self.state();
          s.drag.active = true;
          s.drag.startX = event.clientX;
          s.drag.startY = event.clientY;
          s.drag.left = rect.left;
          s.drag.top = rect.top;
          panel.style.right = "auto";
          event.preventDefault();
        } catch (error) {
          self.logIssue("drag start failed", error);
        }
      });
      doc.addEventListener("mousemove", function(event) {
        try {
          var s = self.state();
          self.moveItemDrag(event);
          if (!s.drag.active) { return; }
          var nextLeft = s.drag.left + (event.clientX - s.drag.startX);
          var nextTop = s.drag.top + (event.clientY - s.drag.startY);
          panel.style.left = Math.max(0, Math.round(nextLeft)) + "px";
          panel.style.top = Math.max(0, Math.round(nextTop)) + "px";
        } catch (error) {
          self.logIssue("drag move failed", error);
        }
      });
      doc.addEventListener("mouseup", function(event) {
        self.state().drag.active = false;
        self.endItemDrag(event);
      });
    } catch (error) {
      this.logIssue("bindDrag failed", error);
    }
  }

  onReady {
    if (String(this.getAttribute("q-builder-palette-preview-node") || "") === "1") { return; }
    if (this.__qBuilderPaletteReady) { return; }
    this.__qBuilderPaletteReady = true;
    this.bindDrag();
    this.applyLayoutMode();
    var self = this;
    this.addEventListener("dblclick", function(event) {
      try {
        if (self.currentMode() !== "embedded") { return; }
        event.preventDefault();
        event.stopPropagation();
      } catch (error) {
        self.logIssue("palette dblclick failed", error);
      }
    }, true);
    this.setHost(this.findHost());
    var doc = this.ownerDocument || document;
    if (doc && typeof doc.addEventListener === "function" && !this.__qBuilderPaletteContentSignalBound) {
      this.__qBuilderPaletteContentSignalBound = true;
      var self = this;
      doc.addEventListener("QHTMLContentLoaded", function(event) {
        try {
          var trackedHost = self.findHost();
          if (!trackedHost || trackedHost.nodeType !== 1) { return; }
          var detail = event && event.detail ? event.detail : {};
          var source = detail && detail.source && detail.source.nodeType === 1 ? detail.source : null;
          if (source) {
            if (source === trackedHost) {
              self.refresh(trackedHost);
              return;
            }
            if (source.closest && source.closest("q-builder[q-builder-runtime='1']")) { return; }
            if (!trackedHost.contains || !trackedHost.contains(source)) { return; }
            if (String(source.tagName || "").toLowerCase() === "q-html") { return; }
          }
          self.refresh(trackedHost);
        } catch (error) {
          self.logIssue("palette content-loaded refresh failed", error);
        }
      });
    }
  }

  div.w3-card.w3-round-large { q-builder-palette: "1"
    style {
      position: fixed;
      right: 1vw;
      top: 8vh;
      width: 42vw;
      height: 42vh;
      min-width: 22rem;
      min-height: 16rem;
      max-width: 90vw;
      max-height: 90vh;
      resize: both;
      overflow: hidden;
      z-index: 1200;
      display: flex;
      flex-direction: column;
      background: #111827;
      border: 1px solid #475569;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    div.w3-bar { q-builder-palette-handle: "1"
      style {
        cursor: move;
        user-select: none;
        background: #1f2937;
        color: #f8fafc;
        flex: 0 0 auto;
      }
      span.w3-bar-item.w3-small { text { palette } }
      button.w3-button.w3-small.w3-right { type: "button" q-builder-palette-action: "refresh" onclick { this.closest("q-builder-palette").refresh(); } text { refresh } }
    }
    div { q-builder-palette-grid: "1"
      style {
        flex: 1 1 auto;
        overflow: auto;
        padding: 0.35rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(8.5rem, 1fr));
        grid-auto-rows: 8.5rem;
        gap: 0.35rem;
        justify-content: start;
        align-content: start;
        background: #0b1220;
      }
    }
  }
}

q-component q-builder-modal-shell {
  q-modal {
    id: "q-builder-edit-modal"
    q-builder-modal: "1"
    title { text { QBuilder } }
    content {
      q-editor { q-builder-editor: "1" initial-qhtml: "div { text { Edit me with QDom } }" }
    }
    footer {
      div.w3-right-align {
        button.w3-button.w3-small.w3-theme-l3.w3-round-large.w3-margin-right { type: "button" q-builder-action: "save" onclick { this.closest("q-builder").save(); } q-builder-icon-save { } span.w3-margin-left { text { Save } } }
        button.w3-button.w3-small.w3-grey.w3-round-large { type: "button" q-builder-action: "close" onclick { this.component.hide(); this.closest("q-builder").markEditModalClosed(); } q-builder-icon-close { } span.w3-margin-left { text { Close } } }
      }
    }
  }
}

q-component q-builder-colors-modal-shell {
  q-modal {
    id: "q-builder-colors-modal-host"
    q-builder-colors-modal: "1"
    title { text { QBuilder Styles } }
    content {
      div.w3-small.w3-margin-bottom.w3-text-blue-grey {
        text { Edit local q-style and q-theme blocks for the selected element. Computed snapshots are shown when local blocks are not defined. }
      }
      q-tabs {
        q-builder-colors-tabs: "1"
        q-tab {
          name { text { q-style } }
          content {
            div.w3-small.w3-margin-bottom.w3-text-blue-grey { text { Computed q-style snapshot for the selected element. } }
            pre.w3-small.w3-padding-small.w3-border.w3-round { q-builder-colors-computed: "q-style" text { q-style selected-style { } } }
            div.w3-margin-top.w3-margin-bottom {
              button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "customize-style" onclick { this.closest("q-builder").customizeStyleForSelected(); } text { Capture Local Style } }
            }
            div.w3-small.w3-margin-top.w3-margin-bottom.w3-text-blue-grey { q-builder-colors-status: "q-style" text { Local q-style block (editable only when defined on selected element). } }
            q-editor { q-builder-colors-editor: "q-style" initial-qhtml: "q-style selected-style { }" }
          }
        }
        q-tab {
          name { text { q-theme } }
          content {
            div.w3-small.w3-margin-bottom.w3-text-blue-grey { text { Computed q-theme snapshot visible for this scope. } }
            pre.w3-small.w3-padding-small.w3-border.w3-round { q-builder-colors-computed: "q-theme" text { q-theme selected-theme { * { selected-style } } } }
            div.w3-row-padding.w3-margin-top {
              div.w3-threequarter {
                select.w3-select.w3-border.w3-round { q-builder-colors-style-select: "1" }
              }
              div.w3-quarter {
                button.w3-button.w3-small.w3-theme-l3.w3-round-large.w3-block { type: "button" q-builder-action: "add-theme-style" onclick { this.closest("q-builder").addThemeStyleToEditor(); } text { Add Style } }
              }
            }
            div.w3-margin-top.w3-margin-bottom {
              button.w3-button.w3-small.w3-theme-l3.w3-round-large { type: "button" q-builder-action: "customize-theme" q-builder-colors-theme-customize: "1" onclick { this.closest("q-builder").customizeThemeForSelected(); } text { Customize Theme } }
            }
            div.w3-small.w3-margin-top.w3-margin-bottom.w3-text-blue-grey { q-builder-colors-status: "q-theme" text { Local q-theme block (editable only when defined on selected element). } }
            q-editor { q-builder-colors-editor: "q-theme" initial-qhtml: "q-theme selected-theme { }" }
          }
        }
      }
    }
    footer {
      div.w3-right-align {
