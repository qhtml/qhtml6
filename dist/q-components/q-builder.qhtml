      return null;
    }
  }

  function saveColors() {
    try {
      var s = this.state();
      var editContext = s.colorsEditContext && typeof s.colorsEditContext === "object" ? s.colorsEditContext : null;
      if (!editContext || !s.target) {
        s.colorsEditContext = null;
        this.setColorsOpen(false);
        return;
      }
      var nextSource = String(editContext.source || "").trim();
      var keywords = ["q-style", "q-theme"];
      for (var i = 0; i < keywords.length; i += 1) {
        var keyword = keywords[i];
        if (!(editContext.editable && editContext.editable[keyword])) { continue; }
        var editorNode = this.querySelector("q-editor[q-builder-colors-editor='" + keyword + "']");
        var editorSource = editorNode && typeof editorNode.getQhtmlSource === "function"
          ? String(editorNode.getQhtmlSource() || "").trim()
          : "";
        var blockSource = editorSource;
        if (!blockSource) {
          blockSource = keyword === "q-style" ? "q-style selected-style { }" : "q-theme selected-theme { }";
        }
        nextSource = this.upsertTopLevelKeywordBlock(nextSource, keyword, blockSource);
      }
      if (!nextSource) {
        s.colorsEditContext = null;
        this.setColorsOpen(false);
        return;
      }
      if (String(nextSource).trim() === String(editContext.source || "").trim()) {
        s.colorsEditContext = null;
        this.setColorsOpen(false);
        return;
      }
      var root = this.qroot();
      var host = s.host && s.host.nodeType === 1 ? s.host : (this.closest ? this.closest("q-html") : null);
      if (!s.target || typeof s.target.replaceWithQHTML !== "function" || !root) {
        s.colorsEditContext = null;
        this.setColorsOpen(false);
        return;
      }
      var replaced = s.target.replaceWithQHTML(nextSource, root);
      if (replaced) {
        if (replaced && typeof replaced === "object") {
          s.target = replaced;
        }
        s.source = nextSource;
        this.touchMutationNonce(host, replaced && typeof replaced === "object" ? replaced : s.target);
        this.requestHostUpdate(host, null);
        this.refreshPalette(host);
      }
      s.colorsEditContext = null;
      this.setColorsOpen(false);
    } catch (error) {
      this.logIssue("saveColors failed", error);
    }
  }

  function ensureSourceModalLayout() {
