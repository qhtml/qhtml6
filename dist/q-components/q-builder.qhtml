  div.w3-card.w3-round-large { q-builder-palette: "1"
    style {
      position: fixed;
      right: 1vw;
      top: 8vh;
      width: 42vw;
      height: 42vh;
      min-width: 22rem;
      min-height: 16rem;
      max-width: 90vw;
      max-height: 90vh;
      resize: both;
      overflow: hidden;
      z-index: 1200;
      display: flex;
      flex-direction: column;
      background: #111827;
      border: 1px solid #475569;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    div.w3-bar { q-builder-palette-handle: "1"
