        overflow: auto;
        padding: 0.35rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, 10vw);
        grid-auto-rows: 10vw;
        gap: 0.35rem;
        justify-content: start;
        align-content: start;
        background: #0b1220;
      }
    }
