        var detail = event && event.detail ? event.detail : {};
        var name = String(detail.name || "").trim().toLowerCase();
        var builder = getBuilder();
        state.paletteDragging = !!name;
        state.paletteName = name;
        state.hovered = null;
        if (builder && typeof builder.setHoverElement === "function") {
          builder.setHoverElement(null);
        }
        if (!builder || !state.paletteDragging || typeof builder.updatePaletteDropTarget !== "function") { return; }
        builder.updatePaletteDropTarget(name, host, Number(detail.clientX || 0), Number(detail.clientY || 0));
