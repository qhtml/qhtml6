  function copySource() {
    try {
      var output = this.querySelector("[q-builder-source-output='1']");
      var text = output && typeof output.value === "string" ? output.value : String(this.state().sourceText || "");
      var globalRef = this.getGlobalRef();
      if (globalRef && globalRef.navigator && globalRef.navigator.clipboard && typeof globalRef.navigator.clipboard.writeText === "function") {
        globalRef.navigator.clipboard.writeText(text);
        return true;
      }
      if (output && typeof output.select === "function") {
        output.focus();
        output.select();
        if (typeof document !== "undefined" && typeof document.execCommand === "function") {
          document.execCommand("copy");
          return true;
        }
      }
    } catch (error) {
      this.logIssue("copySource failed", error);
    }
    return false;
  }

  function downloadSource() {
    try {
      var text = String(this.state().sourceText || "");
      if (!text) { return false; }
      var globalRef = this.getGlobalRef();
      if (!globalRef || typeof globalRef.Blob !== "function" || !globalRef.URL || typeof globalRef.URL.createObjectURL !== "function") {
        return false;
      }
      var blob = new globalRef.Blob([text], { type: "text/plain;charset=utf-8" });
      var url = globalRef.URL.createObjectURL(blob);
      var doc = this.ownerDocument || document;
      var link = doc.createElement("a");
      link.href = url;
      link.download = "page-builder-output.qhtml";
      if (doc.body) { doc.body.appendChild(link); }
      if (typeof link.click === "function") { link.click(); }
      if (link.parentNode && typeof link.parentNode.removeChild === "function") {
        link.parentNode.removeChild(link);
      }
      globalRef.URL.revokeObjectURL(url);
      return true;
    } catch (error) {
      this.logIssue("downloadSource failed", error);
      return false;
    }
  }

  function ensureSlotPickerLayout() {
    try {
      var modal = this.querySelector("q-modal[q-builder-slot-picker-modal='1']");
      if (!modal) { return; }
      var root = modal.querySelector("[q-modal-root='1'], .w3-modal");
